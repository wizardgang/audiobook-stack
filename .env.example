# ============================================================
#  tts-node — environment configuration
#  Copy this file to .env and fill in your values.
#  All variables have sensible defaults; only override what
#  you actually need to change.
# ============================================================


# ── Core infrastructure ──────────────────────────────────────────────────────

# Redis connection URL.
# Local stack: redis://localhost:6379
# Remote / multi-machine: redis://YOUR_SERVER_IP:6379
REDIS_URL=redis://localhost:6379

# Unique identifier for this worker node.
# Used as a Prometheus label — must be different on every machine.
# Examples: local-1, gpu-node-1, colab-worker-1
WORKER_ID=local-1


# ── Directory paths ──────────────────────────────────────────────────────────
# For single-machine setups these can be local paths.
# For multi-machine setups point them at a shared NFS/SMB mount so all
# workers and the merger see the same files.

# Where finished MP3 chunk files are written by workers and read by the merger.
OUTPUT_DIR=./outputs

# Where the orchestrator writes .txt chunk files and meta.json.
CHUNKS_DIR=./chunks

# Where the merger writes the final .m4b / .mp3 audiobooks.
# Also served by Audiobookshelf (port 13378).
AUDIOBOOK_DIR=./audiobooks

# Where the watcher scans for incoming PDF/EPUB files.
WATCH_DIR=./inbox

# How often (seconds) the watcher polls the inbox directory.
POLL_INTERVAL=10


# ── Abogen TTS service ───────────────────────────────────────────────────────

# Base URL of the Abogen Flask API used by workers.
# Local stack (docker-compose): http://abogen-worker:8808
# Remote Abogen instance:       http://YOUR_SERVER_IP:8808
ABOGEN_HOST=http://localhost:8808

# IP the Abogen server binds to inside its container.
# Leave blank to bind to all interfaces (0.0.0.0).
ABOGEN_BIND_IP=

# Port Abogen listens on inside its container.
ABOGEN_PORT=8808


# ── Pipeline tuning ──────────────────────────────────────────────────────────

# Maximum characters per TTS chunk (chapters longer than this are split).
# Smaller = shorter audio files per job, more parallelism.
# Larger = fewer jobs, fewer MP3 seams in the final audiobook.
CHUNK_SIZE_CHARS=3000

# Chapters shorter than this (after cleaning) are silently skipped.
MIN_CHAPTER_CHARS=150

# Comma-separated list of title substrings that cause a chapter to be skipped.
# Leave blank to use the built-in defaults (copyright, index, bibliography, etc.)
# SKIP_CHAPTERS=copyright,acknowledgment,index,bibliography

# Output format for the merged audiobook: m4b (default) or mp3.
OUTPUT_FORMAT=m4b

# Set to "true" to keep individual MP3 chunk files after merging.
KEEP_CHUNKS=false


# ── Worker behaviour ─────────────────────────────────────────────────────────

# Seconds to wait for the TTS API to respond before timing out a chunk job.
TTS_TIMEOUT_S=600

# Set to "true" to enable GPU acceleration inside the worker container
# (requires a CUDA-capable image and nvidia-container-toolkit on the host).
USE_GPU=false

# How long (seconds) the worker waits before retrying when the SMB/NFS
# shared volume is temporarily unreachable.
SMB_RETRY_INTERVAL=30

# Local spool directory used by the worker to stage chunk files before
# copying them to the shared OUTPUT_DIR (useful when OUTPUT_DIR is a slow
# network mount).
SPOOL_DIR=/spool


# ── TTS engine selection ─────────────────────────────────────────────────────
# Controls which synthesis worker handles pipeline:tts jobs.
#
# The Abogen Flask API (port 8808) always starts regardless of this setting —
# the orchestrator needs it for text extraction (/api/extract) and NLP chunking
# (/api/chunk).  Only the synthesis worker changes.
#
#   COMPOSE_PROFILES=abogen-tts              → Abogen/Kokoro handles synthesis (default)
#   COMPOSE_PROFILES=chattts-tts             → ChatTTS worker handles synthesis
#   COMPOSE_PROFILES=                        → F5-TTS worker handles synthesis
#   COMPOSE_PROFILES=abogen-tts,chattts-tts  → run both (jobs self-balance via Redis brpop)
#
COMPOSE_PROFILES=abogen-tts


# ── F5-TTS worker (zero-shot voice cloning) ───────────────────────────────────
# Only relevant when COMPOSE_PROFILES is empty (F5-TTS handles synthesis).

# Unique ID for this F5 worker node (used as a Prometheus label).
F5_WORKER_ID=f5-local-1

# F5-TTS model variant: F5TTS_v1_Base or E2TTS_Base
F5_MODEL=F5TTS_v1_Base

# Device for inference: cpu or cuda
F5_DEVICE=cpu

# Synthesis speed multiplier (0.7 – 1.5)
F5_SPEED=1.0

# Max characters per synthesis call — F5-TTS quality degrades on very long inputs.
F5_MAX_CHARS=1000

# Text spoken in the reference audio file (must match exactly).
# The reference WAV itself goes in f5-worker/ref/reference.wav
F5_REF_TEXT=Some call me nature, others call me mother nature.


# ── ChatTTS worker ────────────────────────────────────────────────────────────
# Only relevant when COMPOSE_PROFILES=chattts-tts.
# ChatTTS synthesizes locally — no external HTTP API required.

# Unique ID for this ChatTTS worker node (used as a Prometheus label).
CHATTTS_WORKER_ID=chattts-local-1

# Device for inference: cpu or cuda
CHATTTS_DEVICE=cpu

# Speech speed: integer 1–9 where 5 is normal pace.
# The per-chunk speed multiplier (from KOKORO_SPEED) scales this base value.
CHATTTS_SPEED=5

# Sampling temperature — lower = more stable, higher = more expressive.
CHATTTS_TEMPERATURE=0.3

# Nucleus sampling parameters.
CHATTTS_TOP_P=0.7
CHATTTS_TOP_K=20

# Integer seed for the speaker embedding.
# Changing this gives a different but consistent voice across all chunks.
CHATTTS_SPEAKER_SEED=42

# Max characters per synthesis segment — quality degrades on very long inputs.
CHATTTS_MAX_CHARS=300

# Prometheus port for the ChatTTS worker.
CHATTTS_PROMETHEUS_PORT=8004


# ── AI text normalisation — OpenRouter (optional) ────────────────────────────
# When OPENROUTER_API_KEY is set, the orchestrator sends each chunk to the
# specified model for TTS pre-processing (expanding abbreviations, fixing
# OCR artifacts, etc.).  Leave blank to skip AI normalisation entirely.

OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001


# ── Kokoro voice blending ─────────────────────────────────────────────────────
# Blend multiple Kokoro voices for each chunk job.
# Accepted formats:
#   "af_bella:60,af_sky:40"        colon-weight (weights auto-normalised)
#   "af_bella*0.6+af_sky*0.4"      native Kokoro formula (passed through as-is)
# Leave blank to use the Abogen server's configured default voice.
KOKORO_VOICE_BLEND=

# TTS speech rate multiplier applied to every chunk (1.0 = normal speed).
KOKORO_SPEED=1.0


# ── Observability ────────────────────────────────────────────────────────────

# IP Prometheus binds to when scraping worker metrics.
# Leave blank to bind to all interfaces.
PROMETHEUS_BIND_IP=

# Prometheus metrics ports (one per service).
# Defaults: watcher=8003, orchestrator=8001, worker=8000, merger=8002
# PROMETHEUS_PORT=8000

# Grafana admin password (default: admin — change before exposing externally).
GRAFANA_PASSWORD=admin

# Timezone used by all containers for log timestamps.
TZ=UTC


# ── NFS shared storage (docker-compose.worker.nfs.yml) ───────────────────────
# Used when deploying remote GPU workers that mount shared storage via NFS.

NFS_SERVER=10.0.0.1
NFS_OUTPUT_PATH=/exports/pipeline/outputs
NFS_CHUNKS_PATH=/exports/pipeline/chunks


# ── SMB / CIFS shared storage (docker-compose.worker.smb.yml) ────────────────
# Used when deploying remote workers that mount shared storage via Samba.

SMB_SERVER=10.0.0.1
SMB_SHARE=pipeline
SMB_USER=pipeline
SMB_PASSWORD=
